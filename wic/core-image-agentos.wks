
bootloader --ptable gpt
part /boot --source bootimg-partition --ondisk mmcblk0 --fstype=vfat --label boot_A --active --align 4096 --size 100
part /boot --source bootimg-partition --ondisk mmbclk0 --fstype=vfat --label boot_B --align 4096 --size 100
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label rootfs_A --align 4096
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label rootfs_B --align 4096
part /data --ondisk mmcblk0 --fstype=ext4 --label data --align 4096 --size 100M --fsoptions "x-systemd.growfs"
